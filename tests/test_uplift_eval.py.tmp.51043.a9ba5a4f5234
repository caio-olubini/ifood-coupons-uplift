"""T-205 — Qini/AUUC reportado; curva renderiza no tema executivo.
T-212 — teste de placebo por permutação (REQ-212)."""

import numpy as np
import pandas as pd
import plotly.graph_objects as go
import pytest

from src.config import load
from src.uplift_eval import (
    _permute_treatment_within_offer_type,
    fig_placebo_distribution,
    fig_qini_curve,
    placebo_qini_distribution,
    placebo_test,
    qini,
    qini_curve_points,
)
from tests.modeling_fixtures import synthetic_processed


def _synthetic_uplift_eval(n=500, seed=0):
    rng = np.random.default_rng(seed)
    treatment = rng.binomial(1, 0.5, size=n)
    uplift = rng.normal(0, 1, size=n)
    # y correlaciona com uplift previsto sob tratamento — sinal real a capturar.
    p = 1 / (1 + np.exp(-(uplift * treatment)))
    y = rng.binomial(1, p)
    return pd.Series(y), pd.Series(uplift), pd.Series(treatment)


def test_qini_score_beats_random_with_planted_signal():
    y, uplift, treatment = _synthetic_uplift_eval()
    score = qini(y, uplift, treatment)
    assert score > 0  # sinal plantado deve ordenar melhor que aleatório (score 0)


def test_qini_curve_renders_in_theme():
    cfg = load()
    y, uplift, treatment = _synthetic_uplift_eval()
    score = qini(y, uplift, treatment)
    curve = qini_curve_points(y, uplift, treatment)

    fig = fig_qini_curve(curve, score, cfg, theme="light")

    assert isinstance(fig, go.Figure)
    assert len(fig.data) == 2  # curva do modelo + referência aleatória
    assert fig.layout.template is not None


# --- T-212 — placebo por permutação (REQ-212) ----------------------------------


def test_permutacao_preserva_proporcao_tratado_controle_por_offer_type():
    """Guarda contra a forma errada de embaralhar: global mudaria a proporção
    por `offer_type` (as taxas de view divergem por tipo no dado real) e o Qini
    nulo cairia por composição de grupo, não por ausência de efeito.
    """
    df = synthetic_processed(n=600, seed=7)
    rng = np.random.default_rng(0)
    permutado = _permute_treatment_within_offer_type(df, rng)

    original = df.groupby("offer_type")["treatment"].mean()
    novo = df.assign(treatment=permutado).groupby("offer_type")["treatment"].mean()
    pd.testing.assert_series_equal(original, novo, check_names=False)

    # Embaralhou de fato — não é uma cópia disfarçada.
    assert not permutado.equals(df["treatment"])


def test_permutacao_mantem_features_e_y_intocados():
    df = synthetic_processed(n=300, seed=8)
    rng = np.random.default_rng(1)
    permutado = _permute_treatment_within_offer_type(df, rng)

    resultado = df.assign(treatment=permutado)
    pd.testing.assert_series_equal(resultado["converted"], df["converted"])
    pd.testing.assert_series_equal(resultado["hist_spend_total"], df["hist_spend_total"])


def test_qini_real_supera_o_limiar_da_nula_quando_ha_sinal_plantado():
    """Aceite de REQ-212: com sinal real plantado (a fixture já planta
    `converted` correlacionado a `treatment` e `hist_spend_total`), o Qini real
    deve furar o percentil da distribuição nula.
    """
    df = synthetic_processed(n=1200, seed=3)
    train_df = df[df["campaign_wave"] < 4].reset_index(drop=True)
    holdout_df = df[df["campaign_wave"] >= 4].reset_index(drop=True)

    cfg = load(xlearner_n_estimators=30, placebo_n_permutations=8)

    from src.uplift import fit_xlearner, predict

    modelos = fit_xlearner(train_df, cfg)
    pred = predict(modelos, holdout_df)
    score_real = qini(holdout_df["converted"], pred["uplift"], holdout_df["treatment"])

    nula = placebo_qini_distribution(train_df, holdout_df, cfg)
    assert len(nula) == cfg.placebo_n_permutations

    resultado = placebo_test(score_real, nula, cfg)
    assert resultado["passou"]
    assert resultado["qini_real"] == score_real


def test_placebo_test_retorna_p_value_e_estatisticas_da_nula():
    nula = np.array([0.0, 0.01, -0.01, 0.02, 0.005])
    cfg = load()

    # Qini real muito acima da nula: passa, p-valor baixo.
    resultado = placebo_test(qini_score=0.5, null_distribution=nula, cfg=cfg)
    assert resultado["passou"] is True
    assert resultado["p_value"] == 0.0
    assert resultado["null_mean"] == pytest.approx(nula.mean())


def test_placebo_test_falha_quando_qini_real_nao_supera_a_nula():
    nula = np.array([0.05, 0.06, 0.04, 0.07, 0.08])
    cfg = load()

    resultado = placebo_test(qini_score=0.03, null_distribution=nula, cfg=cfg)
    assert resultado["passou"] is False
    assert resultado["p_value"] > 0


def test_fig_placebo_distribution_renderiza_no_tema():
    cfg = load()
    nula = np.random.default_rng(0).normal(0, 0.02, size=20)
    fig = fig_placebo_distribution(nula, qini_score=0.1, cfg=cfg, theme="light")

    assert isinstance(fig, go.Figure)
    assert fig.layout.template is not None
